# JuiceFS Configuration
JFS_META_URL=postgres://username:password@your-postgresql-host:5432/juicefs
JFS_STORAGE=s3
JFS_BUCKET=your-bucket-name
JFS_ACCESS_KEY=your-access-key
JFS_SECRET_KEY=your-secret-key

# Mount Configuration
JFS_MOUNT_POINT=/path/to/your/mount/point
JFS_CACHE_DIR=/path/to/cache/directory
JFS_CACHE_SIZE=10240  # 缓存大小，单位MB，默认10GB 