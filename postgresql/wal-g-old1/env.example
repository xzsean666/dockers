# PostgreSQL 基础配置
CONTAINER_NAME=postgres-wal-g
PORT=5432

# PostgreSQL 数据库配置
POSTGRESQL_DATABASE=mydb
POSTGRESQL_USERNAME=myuser
POSTGRESQL_PASSWORD=mypassword
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=replicatorpassword

# WAL-G S3 配置
WALG_S3_PREFIX=s3://your-bucket/wal-g
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# S3兼容存储配置 (可选，如果使用MinIO、Backblaze B2等)
AWS_ENDPOINT_URL=https://s3.your-provider.com
AWS_S3_FORCE_PATH_STYLE=true

# WAL-G 性能配置
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4
WALG_DISK_RATE_LIMIT=10485760
WALG_NETWORK_RATE_LIMIT=10485760

# 备份计划配置
BACKUP_SCHEDULE=0 2 * * *
RETENTION_DAYS=7

# 通知配置 (可选)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK 