# Odyssey PostgreSQL Connection Pooler Configuration
# ===================================================

# Odyssey 服务配置
ODYSSEY_CONTAINER_NAME=odyssey-pooler
ODYSSEY_PORT=6432

# PostgreSQL Master (写操作)
POSTGRES_MASTER_HOST=主数据库的IP地址或主机名
POSTGRES_MASTER_PORT=5432
POSTGRES_MASTER_DB=MyDB
POSTGRES_MASTER_USER=sean
POSTGRES_MASTER_PASSWORD=111111

# PostgreSQL Slave (读操作)
POSTGRES_SLAVE_HOST=从数据库的IP地址或主机名
POSTGRES_SLAVE_PORT=5432
POSTGRES_SLAVE_DB=MyDB
POSTGRES_SLAVE_USER=sean
POSTGRES_SLAVE_PASSWORD=111111

# Odyssey 连接池配置
POOL_SIZE=25
POOL_TIMEOUT=4000
POOL_TTL=60
POOL_CANCEL=yes
POOL_ROLLBACK=yes

# 认证配置
AUTH_TYPE=md5
CLIENT_MAX=100

# 日志配置
LOG_LEVEL=1
LOG_TO_STDOUT=yes
LOG_DEBUG=no
LOG_CONFIG=yes
LOG_SESSION=yes
LOG_QUERY=no

# SSL 配置
TLS_ENABLED=no
TLS_CA_FILE=
TLS_CERT_FILE=
TLS_KEY_FILE=

# 系统配置
WORKERS=4
RESOLVERS=1
READAHEAD=8192
CACHE_COROUTINE=128
COROUTINE_STACK_SIZE=16 