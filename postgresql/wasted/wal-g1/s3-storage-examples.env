# =======================================================================
# PostgreSQL WAL-G S3兼容存储配置示例
# 根据您使用的存储服务，复制对应的配置到 .env 文件中
# =======================================================================

# PostgreSQL 基础配置（所有服务都需要）
CONTAINER_NAME=wordflow-postgresql
POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=MyDB
POSTGRESQL_USERNAME=sean
POSTGRESQL_PASSWORD=111111
POSTGRESQL_REPLICATION_USER=repl_user
POSTGRESQL_REPLICATION_PASSWORD=111111
PORT=15432

# =======================================================================
# 1. Cloudflare R2 配置 (推荐)
# =======================================================================
# S3 bucket path (默认示例，修改为你的bucket)
WALG_S3_PREFIX=s3://mongotest/postgresql-backups

# R2 API Token (从 Cloudflare R2 控制台生成)
AWS_ACCESS_KEY_ID=your-r2-api-token
AWS_SECRET_ACCESS_KEY=your-r2-secret-key

# Region (R2 使用 auto)
AWS_DEFAULT_REGION=auto

# R2 Endpoint (在 R2 控制台的 "API Access" 部分找到)
# 格式: https://[account-id].r2.cloudflarestorage.com
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# 必须启用 path-style 访问
AWS_S3_FORCE_PATH_STYLE=true

# SSL 设置
WALG_S3_USE_SSL=true
AWS_S3_DISABLE_SSL=false

# =======================================================================
# 2. Backblaze B2 配置
# =======================================================================
# # S3 bucket path
# WALG_S3_PREFIX=s3://your-b2-bucket/postgresql-backups
# 
# # B2 Application Key (从 B2 控制台生成)
# AWS_ACCESS_KEY_ID=your-b2-application-key-id
# AWS_SECRET_ACCESS_KEY=your-b2-application-key
# 
# # B2 Region (根据你的区域选择)
# AWS_DEFAULT_REGION=us-west-004
# 
# # B2 S3-compatible endpoint
# S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# 
# # 必须启用 path-style 访问
# AWS_S3_FORCE_PATH_STYLE=true
# 
# # SSL 设置
# WALG_S3_USE_SSL=true

# =======================================================================
# 3. MinIO 自托管配置
# =======================================================================
# # S3 bucket path
# WALG_S3_PREFIX=s3://your-minio-bucket/postgresql-backups
# 
# # MinIO Access Key
# AWS_ACCESS_KEY_ID=your-minio-access-key
# AWS_SECRET_ACCESS_KEY=your-minio-secret-key
# 
# # Region
# AWS_REGION=us-east-1
# 
# # MinIO endpoint
# AWS_ENDPOINT=https://your-minio-server.com:9000
# WALG_S3_ENDPOINT=https://your-minio-server.com:9000
# 
# # 必须启用 path-style 访问
# AWS_S3_FORCE_PATH_STYLE=true
# 
# # SSL 设置 (如果使用 HTTP，设置为 false)
# WALG_S3_USE_SSL=true

# =======================================================================
# 4. DigitalOcean Spaces 配置
# =======================================================================
# # S3 bucket path
# WALG_S3_PREFIX=s3://your-spaces-bucket/postgresql-backups
# 
# # DigitalOcean Spaces Key
# AWS_ACCESS_KEY_ID=your-spaces-access-key
# AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
# 
# # Region
# AWS_REGION=nyc3
# 
# # Spaces endpoint
# AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
# WALG_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# 
# # 启用 path-style 访问
# AWS_S3_FORCE_PATH_STYLE=false

# =======================================================================
# 5. 腾讯云 COS 配置
# =======================================================================
# # S3 bucket path
# WALG_S3_PREFIX=s3://your-cos-bucket/postgresql-backups
# 
# # 腾讯云 COS 密钥
# AWS_ACCESS_KEY_ID=your-cos-secret-id
# AWS_SECRET_ACCESS_KEY=your-cos-secret-key
# 
# # Region
# AWS_REGION=ap-beijing
# 
# # COS endpoint
# AWS_ENDPOINT=https://cos.ap-beijing.myqcloud.com
# WALG_S3_ENDPOINT=https://cos.ap-beijing.myqcloud.com
# 
# # path-style 访问
# AWS_S3_FORCE_PATH_STYLE=false

# =======================================================================
# WAL-G 通用性能配置
# =======================================================================
# 压缩方法 (brotli, lz4, lzma, zstd)
WALG_COMPRESSION_METHOD=brotli

# 增量备份最大步数
WALG_DELTA_MAX_STEPS=6

# 备份间隔（秒）
BACKUP_INTERVAL=21600  # 6 hours

# 上传/下载并发数
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4

# 带宽限制 (bytes/second, 0 表示无限制)
WALG_DISK_RATE_LIMIT=0
WALG_NETWORK_RATE_LIMIT=0

# 日志级别 (ERROR, INFO, DEVEL)
WALG_LOG_LEVEL=INFO

# SSL 证书文件路径 (可选)
WALG_S3_CA_CERT_FILE=

# =======================================================================
# 使用说明：
# 1. 选择一个存储提供商的配置（取消注释对应部分）
# 2. 修改为你的实际凭证和 bucket 信息
# 3. 保存为 .env 文件
# 4. 运行 ./build.sh 构建和启动服务
# =======================================================================
