
# PostgreSQL Configuration
CONTAINER_NAME=wordflow-postgresql

POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=MyDB
POSTGRESQL_USERNAME=sean
POSTGRESQL_PASSWORD=111111
POSTGRESQL_REPLICATION_USER=repl_user
POSTGRESQL_REPLICATION_PASSWORD=111111
PORT=10030

# WAL-G S3 Configuration
# S3 bucket path for storing backups (default path, change bucket name if needed)
WALG_S3_PREFIX=s3://mongotest/postgresql-backups

# S3-Compatible Storage Credentials
# Replace with your actual credentials
AWS_ACCESS_KEY_ID=846f171906f3593a0f082e30cd97f9e0
AWS_SECRET_ACCESS_KEY=b77fced34d790f4e12beb338cfa62558dce7fcfd9aa9076e794c347f1227297f

# Region configuration
AWS_DEFAULT_REGION=auto

# S3 Endpoint Configuration
# For Cloudflare R2 example shown below
S3_ENDPOINT_URL=https://151172ef838f73d5928d316f0f01fba7.r2.cloudflarestorage.com

# Force path-style URLs (required for most S3-compatible services)
AWS_S3_FORCE_PATH_STYLE=true

# SSL/TLS Configuration
WALG_S3_USE_SSL=true
AWS_S3_DISABLE_SSL=false

# Additional S3 configuration for compatibility
WALG_S3_CA_CERT_FILE=

# WAL-G Backup Settings
WALG_COMPRESSION_METHOD=brotli
WALG_DELTA_MAX_STEPS=6
BACKUP_INTERVAL=21600  # 6 hours in seconds