# PostgreSQL 基础配置
CONTAINER_NAME=wordflow-postgresql
PORT=5051

# PostgreSQL 数据库配置
POSTGRESQL_DATABASE=MyDB
POSTGRESQL_USERNAME=sean
POSTGRESQL_PASSWORD=111111
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=111111

# WAL-G Local File System 配置
WALG_FILE_PREFIX=file:///bitnami/postgresql/local_wal_g_backups

# WAL-G S3 配置
# WALG_S3_PREFIX=s3://pgbackup
# AWS_ACCESS_KEY_ID=38978d5bde1032e4685e2d010f975224
# AWS_SECRET_ACCESS_KEY=ced53136e7211978f6d1005c07a01006dc79192cf5f15974e6be5a6afaa136ec
# AWS_REGION=auto

# S3兼容存储配置 (可选，如果使用MinIO、Backblaze B2等)
# AWS_ENDPOINT_URL=https://151172ef838f73d5928d316f0f01fba7.r2.cloudflarestorage.com
# WALG_S3_ENDPOINT_SOURCE=https://151172ef838f73d5928d316f0f01fba7.r2.cloudflarestorage.com
# AWS_S3_FORCE_PATH_STYLE=true

# WAL-G 性能配置
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4
WALG_DISK_RATE_LIMIT=10485760
WALG_NETWORK_RATE_LIMIT=10485760

# 备份计划配置 
BACKUP_SCHEDULE="0 2 * * 0"
RETENTION_DAYS=7

# 通知配置 (可选)
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK 


