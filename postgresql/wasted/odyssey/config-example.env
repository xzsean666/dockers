# Odyssey PostgreSQL Connection Pooler Configuration
# ===================================================
# 这是一个配置示例文件，请复制为 example.odyssey.env 并修改相应的值

# Odyssey 服务配置
# -----------------
ODYSSEY_CONTAINER_NAME=odyssey-pooler
ODYSSEY_PORT=6432

# PostgreSQL Master (写操作)
# --------------------------
# 主数据库服务器配置 - 处理所有写操作 (INSERT, UPDATE, DELETE, DDL)
POSTGRES_MASTER_HOST=192.168.1.100     # 替换为实际的主数据库IP地址
POSTGRES_MASTER_PORT=5432               # 主数据库端口
POSTGRES_MASTER_DB=MyDB                 # 数据库名称
POSTGRES_MASTER_USER=sean               # 数据库用户名
POSTGRES_MASTER_PASSWORD=111111         # 数据库密码

# PostgreSQL Slave (读操作)
# -------------------------
# 从数据库服务器配置 - 处理所有读操作 (SELECT)
POSTGRES_SLAVE_HOST=192.168.1.101      # 替换为实际的从数据库IP地址
POSTGRES_SLAVE_PORT=5432                # 从数据库端口
POSTGRES_SLAVE_DB=MyDB                  # 数据库名称 (通常与主库相同)
POSTGRES_SLAVE_USER=sean                # 数据库用户名
POSTGRES_SLAVE_PASSWORD=111111          # 数据库密码

# Odyssey 连接池配置
# ------------------
POOL_SIZE=25                # 每个数据库的连接池大小
POOL_TIMEOUT=4000           # 连接超时时间(毫秒)
POOL_TTL=60                 # 连接生存时间(秒)
POOL_CANCEL=yes             # 是否支持查询取消
POOL_ROLLBACK=yes           # 是否自动回滚

# 认证配置
# --------
AUTH_TYPE=md5               # 认证方式: plain, md5, scram-sha-256
CLIENT_MAX=100              # 最大客户端连接数

# 日志配置
# --------
LOG_LEVEL=1                 # 日志级别
LOG_TO_STDOUT=yes           # 输出到标准输出
LOG_DEBUG=no                # 调试日志 (生产环境建议设为 no)
LOG_CONFIG=yes              # 配置日志
LOG_SESSION=yes             # 会话日志
LOG_QUERY=no                # 查询日志 (开启会影响性能)

# SSL 配置
# --------
TLS_ENABLED=no              # 是否启用 TLS
TLS_CA_FILE=                # CA 证书文件路径
TLS_CERT_FILE=              # 服务器证书文件路径
TLS_KEY_FILE=               # 服务器私钥文件路径

# 系统配置
# --------
WORKERS=4                   # 工作线程数 (建议设为 CPU 核心数)
RESOLVERS=1                 # DNS 解析器数量
READAHEAD=8192              # 读缓冲区大小
CACHE_COROUTINE=128         # 协程缓存数量
COROUTINE_STACK_SIZE=16     # 协程栈大小 (KB)

# =======================================================================
# 配置说明
# =======================================================================

# 1. 读写分离原理:
#    - 写操作通过 write_${POSTGRES_MASTER_DB} 数据库连接到主库
#    - 读操作通过 read_${POSTGRES_SLAVE_DB} 数据库连接到从库
#    - 默认连接 ${POSTGRES_MASTER_DB} 连接到主库 (用于管理操作)

# 2. 应用程序使用示例:
#    写操作: psql -h localhost -p 6432 -d write_MyDB -U write_sean
#    读操作: psql -h localhost -p 6432 -d read_MyDB -U read_sean

# 3. 连接字符串示例:
#    写: postgresql://write_sean:111111@localhost:6432/write_MyDB
#    读: postgresql://read_sean:111111@localhost:6432/read_MyDB

# 4. 性能调优建议:
#    - POOL_SIZE: 根据应用并发数和数据库性能调整
#    - WORKERS: 通常设为 CPU 核心数
#    - CLIENT_MAX: 根据预期客户端连接数设置
#    - LOG_QUERY: 仅在调试时开启，生产环境会影响性能

# 5. 安全建议:
#    - 使用强密码
#    - 在生产环境中启用 TLS
#    - 限制网络访问
#    - 定期更新 Odyssey 版本

# 6. 监控建议:
#    - 启用 LOG_SESSION 监控连接状态
#    - 使用 docker-compose logs -f odyssey 查看日志
#    - 监控主从数据库的复制延迟 