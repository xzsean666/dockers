# PostgreSQL 数据库配置
# ======================

# 主数据库配置
POSTGRES_PRIMARY_HOST=your-primary-host
POSTGRES_PRIMARY_PORT=5432

# 从数据库配置  
POSTGRES_REPLICA_HOST=your-replica-host
POSTGRES_REPLICA_PORT=5432

# 数据库连接信息
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=postgres

# Pgpool 服务配置
# ================

# Pgpool 端口映射
PGPOOL_PORT=5432

# Pgpool 管理员配置
PGPOOL_ADMIN_USERNAME=admin
PGPOOL_ADMIN_PASSWORD=admin_password

# 读写分离配置
# ============

# 是否启用负载均衡 (yes/no)
PGPOOL_ENABLE_LOAD_BALANCING=yes

# 负载均衡模式 (on/off)
PGPOOL_LOAD_BALANCE_MODE=on

# 流复制检查配置
# =============

# 流复制检查周期 (秒)
PGPOOL_SR_CHECK_PERIOD=10

# 延迟阈值 (微秒)
PGPOOL_DELAY_THRESHOLD=10000000

# 健康检查配置
# ===========

# 健康检查周期 (秒)
PGPOOL_HEALTH_CHECK_PERIOD=30

# 健康检查超时 (秒)
PGPOOL_HEALTH_CHECK_TIMEOUT=20

# 健康检查最大重试次数
PGPOOL_HEALTH_CHECK_MAX_RETRIES=3

# 健康检查重试延迟 (秒)
PGPOOL_HEALTH_CHECK_RETRY_DELAY=1

# 连接池配置
# ==========

# 子进程生命周期 (秒)
PGPOOL_CHILD_LIFE_TIME=300

# 子进程最大连接数
PGPOOL_CHILD_MAX_CONNECTIONS=50

# 连接生命周期 (秒)
PGPOOL_CONNECTION_LIFE_TIME=600

# 客户端空闲限制 (秒, 0=无限制)
PGPOOL_CLIENT_IDLE_LIMIT=0

# 最大连接池数
PGPOOL_MAX_POOL=15

# 初始子进程数
PGPOOL_NUM_INIT_CHILDREN=32

# 日志配置
# ========

# 是否启用每节点语句日志 (yes/no)
PGPOOL_ENABLE_LOG_PER_NODE_STATEMENT=yes

# 是否记录SQL语句 (on/off)
PGPOOL_LOG_STATEMENT=on

# 是否记录连接日志 (on/off)
PGPOOL_LOG_CONNECTIONS=on

# 其他配置
# ========

# 是否启用LDAP (yes/no)
PGPOOL_ENABLE_LDAP=no

# Docker网络配置 (可选)
# ===================

# 如果数据库在同一Docker网络中，请设置网络名称
# DOCKER_NETWORK_NAME=your_database_network 