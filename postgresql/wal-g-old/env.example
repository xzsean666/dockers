# PostgreSQL Configuration
POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=myapp
POSTGRESQL_USERNAME=myuser
POSTGRESQL_PASSWORD=changeme123!
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=changeme123!

# Database Port
PORT=5432

# WAL-G S3 Configuration (支持AWS S3和Backblaze B2)
WALG_S3_PREFIX=s3://your-bucket-name/path/to/backups

# 访问凭据 (AWS S3或B2 Application Keys)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3服务配置
# 对于AWS S3，使用标准区域如: us-east-1, us-west-2, eu-west-1等
# 对于Backblaze B2，使用: us-west-004 (或其他B2区域)
AWS_REGION=us-east-1

# S3 Endpoint (可选)
# 对于AWS S3: 留空或注释掉 (使用默认endpoint)
# 对于Backblaze B2: https://s3.us-west-004.backblazeb2.com
# AWS_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Path Style配置 (可选)
# 对于AWS S3: 可以留空或设为false
# 对于Backblaze B2: 必须设为true
# AWS_S3_FORCE_PATH_STYLE=true

# 替代的endpoint配置方式 (与AWS_ENDPOINT_URL二选一)
# WALG_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# 性能配置
# AWS S3建议: 4-8并发
# Backblaze B2建议: 2-4并发
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4

# Backup Restoration Settings
# Set to true to restore from backup on startup
RESTORE_FROM_BACKUP=false
# Backup name to restore from (LATEST or specific backup name)
BACKUP_NAME=LATEST

# Optional: Additional PostgreSQL Configuration
# POSTGRESQL_MAX_CONNECTIONS=100
# POSTGRESQL_SHARED_BUFFERS=256MB
# POSTGRESQL_EFFECTIVE_CACHE_SIZE=1GB

# ===========================================
# 快速配置模板：
# ===========================================

# 🔹 AWS S3 配置示例:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# # AWS_ENDPOINT_URL留空
# # AWS_S3_FORCE_PATH_STYLE留空或false
# WALG_UPLOAD_CONCURRENCY=4
# WALG_DOWNLOAD_CONCURRENCY=4

# 🔹 Backblaze B2 配置示例:
# AWS_REGION=us-west-004
# AWS_ACCESS_KEY_ID=your-b2-application-key-id
# AWS_SECRET_ACCESS_KEY=your-b2-application-key
# AWS_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# AWS_S3_FORCE_PATH_STYLE=true
# WALG_UPLOAD_CONCURRENCY=2
# WALG_DOWNLOAD_CONCURRENCY=2 