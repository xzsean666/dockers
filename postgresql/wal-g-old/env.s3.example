# PostgreSQL Configuration
POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=myapp
POSTGRESQL_USERNAME=myuser
POSTGRESQL_PASSWORD=changeme123!
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=changeme123!

# Database Port
PORT=5432

# WAL-G AWS S3 Configuration
WALG_S3_PREFIX=s3://your-s3-bucket-name/path/to/backups

# AWS访问凭据
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# AWS区域 (选择你的S3 bucket所在区域)
AWS_REGION=us-east-1

# S3性能优化
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4

# Backup Restoration Settings
RESTORE_FROM_BACKUP=false
BACKUP_NAME=LATEST

# Optional: Additional PostgreSQL Configuration
# POSTGRESQL_MAX_CONNECTIONS=100
# POSTGRESQL_SHARED_BUFFERS=256MB
# POSTGRESQL_EFFECTIVE_CACHE_SIZE=1GB 