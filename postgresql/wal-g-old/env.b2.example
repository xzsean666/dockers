# PostgreSQL Configuration
POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=myapp
POSTGRESQL_USERNAME=myuser
POSTGRESQL_PASSWORD=changeme123!
POSTGRESQL_REPLICATION_USER=replicator
POSTGRESQL_REPLICATION_PASSWORD=changeme123!

# Database Port
PORT=5432

# WAL-G Backblaze B2 Configuration
# B2配置需要使用s3协议前缀，但指向B2的bucket
WALG_S3_PREFIX=s3://your-b2-bucket-name/path/to/backups

# B2 Application Key和Key ID
# 这些从B2控制台获取 - Application Keys页面
AWS_ACCESS_KEY_ID=your-b2-application-key-id
AWS_SECRET_ACCESS_KEY=your-b2-application-key

# B2特定配置
# B2的S3兼容endpoint (根据你的区域选择)
AWS_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
# 或者使用环境变量方式
# WALG_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# B2区域设置 (B2使用us-west-004格式)
AWS_REGION=us-west-004

# 强制使用path-style访问 (B2要求)
AWS_S3_FORCE_PATH_STYLE=true

# Backup Restoration Settings
RESTORE_FROM_BACKUP=false
BACKUP_NAME=LATEST

# B2特定的性能优化
# B2建议的并发设置
WALG_UPLOAD_CONCURRENCY=2
WALG_DOWNLOAD_CONCURRENCY=2

# Optional: Additional PostgreSQL Configuration
# POSTGRESQL_MAX_CONNECTIONS=100
# POSTGRESQL_SHARED_BUFFERS=256MB
# POSTGRESQL_EFFECTIVE_CACHE_SIZE=1GB 