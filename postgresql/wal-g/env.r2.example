# .env 文件示例 for Cloudflare R2

# PostgreSQL Configuration (示例，根据您的需求修改)
POSTGRESQL_REPLICATION_MODE=master
POSTGRESQL_DATABASE=mydatabase
POSTGRESQL_USERNAME=myuser
POSTGRESQL_PASSWORD=mypassword
POSTGRESQL_REPLICATION_USER=repl_user
POSTGRESQL_REPLICATION_PASSWORD=repl_password
PORT=5432

# WAL-G Configuration for Cloudflare R2
# WALG_S3_PREFIX: 指定您的 R2 桶名称和可选的路径。
# 格式: s3://<您的R2桶名称>/<可选的路径>
WALG_S3_PREFIX=s3://your-r2-bucket-name/postgresql_backups

# AWS_ACCESS_KEY_ID: 您的 R2 Access Key ID
# 在 Cloudflare R2 控制台生成 S3 API Keys 获得
AWS_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID

# AWS_SECRET_ACCESS_KEY: 您的 R2 Secret Access Key
# 在 Cloudflare R2 控制台生成 S3 API Keys 获得
AWS_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# AWS_REGION: R2 不需要特定的区域，可以设置为 auto 或任意字符串
AWS_REGION=auto

# AWS_ENDPOINT_URL: 您的 R2 Endpoint URL
# 格式: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# 在 Cloudflare R2 控制台的 "API Access" 部分找到
AWS_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# AWS_S3_FORCE_PATH_STYLE: 必须设置为 true 以兼容 R2
AWS_S3_FORCE_PATH_STYLE=true

# WALG_S3_ENDPOINT: 通常和 AWS_ENDPOINT_URL 相同
WALG_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# WAL-G Performance Tuning (可选，根据需要调整)
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4

# Restoration configuration (如果您需要从备份恢复)
# RESTORE_FROM_BACKUP=true
# BACKUP_NAME=LATEST # 或指定特定的备份名称