# ==============================================================================
# 基础配置
# ==============================================================================

# 定时备份计划 (cron 格式, 默认: 每天凌晨2点)
CRON_SCHEDULE=0 2 * * *

# 容器启动时立即执行一次备份 (true/false)
RUN_ON_STARTUP=false

# 时区
TZ=Asia/Shanghai

# 本地备份保留份数 (默认: 7)
MAX_BACKUPS=7

# 云端备份保留份数 (默认: 与 MAX_BACKUPS 相同)
# CLOUD_MAX_BACKUPS=14

# zstd 压缩等级 (1-19, 默认: 3, 越高压缩率越好但越慢)
COMPRESSION_LEVEL=3

# 备份文件名前缀 (可选, 用于区分不同服务器)
# BACKUP_PREFIX=myserver

# 排除文件模式 (逗号分隔, 可选)
# EXCLUDE_PATTERNS=*.log,*.tmp,node_modules,.git

# Dry Run 模式 (1=仅模拟, 不实际执行)
DRY_RUN=0

# ==============================================================================
# 本地备份目录 (可选)
# 如果不设置，仅备份到云端
# 需要在 docker-compose.yml 中挂载对应的 volume
# ==============================================================================
BACKUP_LOCAL_DIR=/backups

# ==============================================================================
# S3 兼容存储 (可选 - 支持 AWS S3, MinIO 等)
# ==============================================================================
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=my-backup-bucket
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1
# S3_PATH=backups
# S3_FORCE_PATH_STYLE=false

# ==============================================================================
# Backblaze B2 (可选)
# ==============================================================================
# B2_ACCOUNT_ID=004dce2b7562e520000000003
# B2_APP_KEY=K0041uGkNK6od+ul+3Us/Kc4S8OH0zk
# B2_BUCKET=temp-sean
# B2_PATH=backups

# ==============================================================================
# Cloudflare R2 (可选)
# ==============================================================================
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your-r2-access-key
# R2_SECRET_KEY=your-r2-secret-key
# R2_BUCKET=my-r2-bucket
# R2_PATH=backups

# ==============================================================================
# Slack 通知 (可选)
# ==============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
