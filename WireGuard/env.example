# WireGuard Configuration Environment Variables
# Copy this file to .env and modify the values according to your needs

# User and Group IDs (use 'id' command to get your user's UID/GID)
PUID=1000
PGID=1000

# Timezone (use 'timedatectl' to see available timezones)
TZ=Asia/Shanghai

# Server Configuration
# Your server's public IP address or domain name
SERVER_URL=auto
# WireGuard server port
SERVER_PORT=51820
# Web UI port (optional, for management interface)
WEB_PORT=5000

# Client Configuration
# Number of client configurations to generate (server only)
PEERS_COUNT=1
# Peer DNS servers (comma separated)
PEER_DNS=auto
# Internal subnet for WireGuard network
INTERNAL_SUBNET=10.13.13.0

# Network Configuration
# Allowed IPs for clients (use 0.0.0.0/0 for full tunnel)
ALLOWED_IPS=0.0.0.0/0

# Logging
# Set to true to log peer configurations
LOG_CONFS=true

# Storage Configuration
# Path to store WireGuard configuration files
# Server config path
CONFIG_PATH=./config
# Client config path (for client setup)
# CONFIG_PATH=./client-config

# Additional Notes:
# 1. For server setup: Use the server/ directory
# 2. For client setup: Use the client/ directory and copy config from server
# 3. Make sure to open the SERVER_PORT on your firewall/router
# 4. The server will generate client configurations automatically
# 5. Client configs can be found in server's config/peerX/ directories
