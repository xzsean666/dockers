# Docker 配置文件
# 复制到其他项目只需修改这个文件即可

# ========== 基础信息 ==========
PROJECT_NAME=lst-service
TIMEZONE=Asia/Shanghai

# ========== 应用配置 ==========
# 不需要备用启动脚本，使用PM2管理

# ========== PM2配置 ==========
# 是否启用PM2 (true/false)
PM2_ENABLED=true
PM2_SCRIPT=main/src/tg/astakeBot.js
PM2_NAME=astakeBot

# ========== Cron配置 ==========
# 是否启用定时任务 (true/false)
CRON_ENABLED=true
# 定时任务命令 (每行一个任务，用分号分隔)
CRON_JOBS="\
*/10 * * * * cd /app && node main/src/bot/task.js --type min >> /var/log/cron.log 2>&1;\
0 2 * * * cd /app && node main/src/bot/task.js --type day >> /var/log/cron.log 2>&1\
"

# ========== 日志配置 ==========
LOG_MAX_SIZE=100m
LOG_MAX_FILES=3 